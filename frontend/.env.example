# === Universe Reborn — Frontend Environment Variables ===
# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

# URL de base de l'API Flask/Gunicorn (sans slash final)
# En développement : http://localhost:8000
# En production via Docker : http://web:8000
VITE_API_URL=http://localhost:8000

# Nom du site (optionnel, affiché dans le titre)
VITE_SITE_NAME=Universe Reborn

# Mode debug React Query (true/false)
VITE_DEBUG=false
