# =============================================================
#  Universe Reborn — Configuration
#  Copiez ce fichier en .env et remplissez les valeurs
# =============================================================

# --- Flask ---
FLASK_ENV=production
SECRET_KEY=changeme-remplacez-par-une-cle-aleatoire-forte-32chars

# --- Base de données ---
# SQLite (simple, recommandé pour débuter) :
DATABASE_URL=sqlite:///universe_reborn.db
# MySQL/MariaDB (production) :
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/universe_reborn

# --- Gunicorn ---
PORT=8000
GUNICORN_WORKERS=2

# --- Discord OAuth2 (optionnel) ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://votre-domaine.fr/auth/discord/callback

# --- Discord Webhook (optionnel, pour les logs) ---
DISCORD_WEBHOOK_URL=
