# =============================================================
#  Universe Reborn — Variables d'environnement
#  Copiez ce fichier en .env et remplissez TOUTES les valeurs
# =============================================================

# --- Flask ---
FLASK_ENV=production
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=remplacez-par-une-cle-aleatoire-de-64-caracteres-minimum

# --- Base de données Universe Reborn (tables ur_*) ---
# MySQL/MariaDB (recommandé en production) :
DATABASE_URL=mysql+pymysql://ur_user:ur_password@localhost:3306/universe_reborn
# SQLite (développement uniquement) :
# DATABASE_URL=sqlite:///universe_reborn.db

# --- Base DarkflameServer (lecture seule) ---
# Même serveur MySQL que ci-dessus, base différente :
DARKFLAME_DATABASE_URL=mysql+pymysql://df_user:df_password@localhost:3306/darkflame
# Si Universe Reborn et DarkflameServer partagent la même base :
# DARKFLAME_DATABASE_URL=mysql+pymysql://ur_user:ur_password@localhost:3306/universe_reborn

# --- Gunicorn (Pterodactyl) ---
PORT=8000
GUNICORN_WORKERS=2

# --- Discord OAuth2 (optionnel) ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://votre-domaine.fr/auth/discord/callback

# --- Discord Webhook (logs admin, optionnel) ---
DISCORD_WEBHOOK_URL=
