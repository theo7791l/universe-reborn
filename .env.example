# Configuration Universe Reborn
# Copier ce fichier en .env et remplir les valeurs

# Flask
SECRET_KEY=changez-moi-en-production
FLASK_ENV=development
FLASK_DEBUG=1

# Base de données
DB_HOST=localhost
DB_PORT=3306
DB_NAME=universe_reborn
DB_USER=ur_user
DB_PASSWORD=votre_mot_de_passe
DATABASE_URL=mysql+pymysql://ur_user:votre_mot_de_passe@localhost:3306/universe_reborn

# DarkflameServer
DFS_HOST=localhost
DFS_AUTH_PORT=1001
DFS_MASTER_PORT=5000

# Discord OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://universe-reborn.digital/auth/discord/callback
DISCORD_INVITE_URL=https://discord.gg/votre-serveur

# Mail
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@universe-reborn.digital

# Sécurité
ALLOWED_HOSTS=localhost,universe-reborn.digital,universe.hostepics.fr
